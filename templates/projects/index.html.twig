{% extends 'base.html.twig' %}

{% block title %}{{ 'projects.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'projects.meta.description'|trans }}{% endblock %}

{% block body %}
    {% include 'partials/_hero.html.twig' with {
        hero_overlay: 'hero-projects-overlay',
        hero_title: 'projects.hero.title'|trans,
        hero_description: 'projects.hero.description'|trans,
        hero_cta: [{text: 'projects.hero.btn_portfolio'|trans, href: '#gallery'}],
    } %}
    {% include 'projects/_gallery.html.twig' %}
    {% include 'partials/_cta_section.html.twig' with {
        cta_style: 'blue',
        cta_show_grid: true,
        cta_title: 'projects.cta.title'|trans,
        cta_description: 'projects.cta.description'|trans,
        cta_buttons: [
            {text: 'projects.cta.btn_quote'|trans, href: path('app_quote'), style: 'primary'},
            {text: 'projects.cta.btn_contact'|trans, href: path('app_contact'), style: 'outline'},
        ],
    } %}
{% endblock %}
