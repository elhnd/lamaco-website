{# Project Testimonial — Client quote block #}
<section class="bg-[#F0F4F8] py-24" data-controller="scroll-reveal">
    <div class="max-w-4xl mx-auto px-4 text-center">
        <span class="material-symbols-outlined text-6xl text-primary/20 mb-8 block opacity-0"
              aria-hidden="true"
              data-scroll-reveal-target="item">
            format_quote
        </span>
        <blockquote class="text-2xl md:text-3xl font-medium text-primary italic leading-relaxed mb-8 opacity-0"
                    data-scroll-reveal-target="item">
            &ldquo;{{ project.testimonial.quote }}&rdquo;
        </blockquote>
        <div class="flex items-center justify-center gap-4 opacity-0"
             data-scroll-reveal-target="item">
            <div class="text-left">
                <p class="font-bold text-primary">{{ project.testimonial.author }}</p>
                <p class="text-sm text-gray-500 uppercase tracking-widest">{{ project.testimonial.role }}</p>
            </div>
        </div>
    </div>
</section>
