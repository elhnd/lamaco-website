        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6">
            {% for project in projects %}
                <a href="{{ path('app_projects_show', {slug: project.slug}) }}"
                   class="{{ project.span }} {{ project.height }} relative group overflow-hidden project-card opacity-0 block"
                   data-scroll-reveal-target="item">
                    <img alt="{{ project.alt }}"
                         class="parallax-img"
                         loading="lazy"
                         src="{{ project.image }}">
                    <div class="absolute inset-0 project-card-gradient flex flex-col justify-end p-8 md:p-12">
                        <span class="text-accent text-xs font-bold uppercase tracking-widest mb-2">{{ project.category }}</span>
                        <h3 class="text-white {{ project.titleSize }} font-bold font-display uppercase tracking-tight">{{ project.title }}</h3>
                        <p class="text-white/80 font-display text-sm mt-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm" aria-hidden="true">location_on</span> {{ project.location }}
                        </p>
                    </div>
                </a>
            {% endfor %}
        </div>

