{% extends 'base.html.twig' %}

{% block title %}{{ 'site.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'site.description'|trans }}{% endblock %}

{% block body %}
    {% include 'home/_hero.html.twig' %}
    {% include 'home/_partners.html.twig' %}
    {% include 'home/_about.html.twig' %}
    {% include 'home/_materials.html.twig' %}
    {% include 'home/_services.html.twig' %}
    {% include 'home/_stats.html.twig' %}
    {% include 'home/_testimonials.html.twig' %}
    {% include 'partials/_cta_section.html.twig' with {
        cta_style: 'accent',
        cta_title: 'home.cta.title'|trans,
        cta_description: 'home.cta.description'|trans,
        cta_buttons: [{text: 'home.cta.btn_quote'|trans, href: '#contact'}],
    } %}
    {% include 'home/_contact.html.twig' %}
{% endblock %}
