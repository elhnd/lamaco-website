{# Contact Section — Contact info + Quote request form #}
<section class="py-24 bg-background-light dark:bg-background-dark"
         id="contact"
         aria-labelledby="contact-heading"
         data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16">
            {# Contact Info #}
            <div class="opacity-0" data-scroll-reveal-target="item">
                <h2 id="contact-heading" class="text-4xl font-bold text-primary dark:text-white font-display mb-8">
                    {{ 'home.contact.title'|trans }}
                </h2>
                <p class="text-gray-600 dark:text-gray-400 mb-10 text-lg">
                    {{ 'home.contact.description'|trans }}
                </p>

                <div class="space-y-6">
                    {% set contact_items = [
                        { icon: 'phone', label: 'home.contact.call_us'|trans, value: '+221 33 800 00 00', href: 'tel:+221338000000' },
                        { icon: 'mail', label: 'home.contact.email_us'|trans, value: 'contact@lamaco.sn', href: 'mailto:contact@lamaco.sn' },
                        { icon: 'location_on', label: 'home.contact.visit_us'|trans, value: 'Avenue Cheikh Anta Diop, Dakar, Senegal', href: null },
                    ] %}
                    {% for item in contact_items %}
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 bg-primary/5 rounded flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary" aria-hidden="true">{{ item.icon }}</span>
                            </div>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">{{ item.label }}</p>
                                {% if item.href %}
                                    <a href="{{ item.href }}" class="font-bold text-primary dark:text-white hover:text-accent transition-colors">
                                        {{ item.value }}
                                    </a>
                                {% else %}
                                    <p class="font-bold text-primary dark:text-white">{{ item.value }}</p>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# Contact Form #}
            <div class="bg-white dark:bg-neutral-dark p-8 rounded shadow-xl border border-gray-100 dark:border-gray-800 opacity-0"
                 data-scroll-reveal-target="item">
                <form action="#" method="post" class="space-y-4" novalidate>
                    <div class="grid sm:grid-cols-2 gap-4">
                        <div>
                            <label for="contact-first-name" class="block text-xs font-bold uppercase text-gray-500 mb-2">{{ 'home.contact.first_name'|trans }}</label>
                            <input id="contact-first-name"
                                   name="first_name"
                                   type="text"
                                   autocomplete="given-name"
                                   required
                                   class="w-full bg-gray-50 dark:bg-background-dark border-gray-200 dark:border-gray-800 rounded p-3 text-sm focus:ring-accent focus:border-accent">
                        </div>
                        <div>
                            <label for="contact-last-name" class="block text-xs font-bold uppercase text-gray-500 mb-2">{{ 'home.contact.last_name'|trans }}</label>
                            <input id="contact-last-name"
                                   name="last_name"
                                   type="text"
                                   autocomplete="family-name"
                                   required
                                   class="w-full bg-gray-50 dark:bg-background-dark border-gray-200 dark:border-gray-800 rounded p-3 text-sm focus:ring-accent focus:border-accent">
                        </div>
                    </div>

                    <div>
                        <label for="contact-email" class="block text-xs font-bold uppercase text-gray-500 mb-2">{{ 'home.contact.work_email'|trans }}</label>
                        <input id="contact-email"
                               name="email"
                               type="email"
                               autocomplete="email"
                               required
                               class="w-full bg-gray-50 dark:bg-background-dark border-gray-200 dark:border-gray-800 rounded p-3 text-sm focus:ring-accent focus:border-accent">
                    </div>

                    <div>
                        <label for="contact-service" class="block text-xs font-bold uppercase text-gray-500 mb-2">{{ 'home.contact.service_required'|trans }}</label>
                        <select id="contact-service"
                                name="service"
                                required
                                class="w-full bg-gray-50 dark:bg-background-dark border-gray-200 dark:border-gray-800 rounded p-3 text-sm focus:ring-accent focus:border-accent">
                            <option value="construction_materials">{{ 'home.contact.construction_materials'|trans }}</option>
                            <option value="equipment_rental">{{ 'home.contact.equipment_rental'|trans }}</option>
                            <option value="logistics">{{ 'home.contact.logistics'|trans }}</option>
                            <option value="general">{{ 'home.contact.general_inquiry'|trans }}</option>
                        </select>
                    </div>

                    <div>
                        <label for="contact-message" class="block text-xs font-bold uppercase text-gray-500 mb-2">{{ 'home.contact.message'|trans }}</label>
                        <textarea id="contact-message"
                                  name="message"
                                  rows="4"
                                  required
                                  class="w-full bg-gray-50 dark:bg-background-dark border-gray-200 dark:border-gray-800 rounded p-3 text-sm focus:ring-accent focus:border-accent"></textarea>
                    </div>

                    <button type="submit"
                            class="w-full bg-primary text-white font-bold py-4 rounded uppercase tracking-widest hover:bg-opacity-95 transition-all">
                        {{ 'form.send_message'|trans }}
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
