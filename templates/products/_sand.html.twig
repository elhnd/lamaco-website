{# Sand Varieties Section — Horizontal product cards #}
<section id="sand" aria-labelledby="sand-heading" data-controller="scroll-reveal">
    <div class="flex items-center gap-4 mb-10 opacity-0" data-scroll-reveal-target="item">
        <h2 id="sand-heading" class="text-3xl font-bold text-primary font-display">{{ 'products.sand.title'|trans }}</h2>
        <div class="h-1 flex-grow bg-gray-200" aria-hidden="true"></div>
        <span class="bg-accent/10 text-accent px-3 py-1 text-xs font-bold uppercase rounded">{{ 'products.sand.badge'|trans }}</span>
    </div>

    {% set sand_products = [
        {
            name: 'products.sand.tasseb_name'|trans,
            slug: 'tasseb-sand',
            alt: 'products.sand.tasseb_alt'|trans,
            description: 'products.sand.tasseb_desc'|trans,
            image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD0Of2F3N8OniYJn5lb3Iv30Fnneo8ocFQ-NhFh1Zn27EosrxcSzHU51xUMr_qgILbVUW-6K_ib0JSu-UuQwAKCcjAqkxq3elascmzarNgolLLwYadWuxeE4r7mUn7ZSshZc9OneDXdMlKnO6EhKyo7wtMFB7W9xbyzm7TiMJuhxqCqysqw2M2ypNGKrYp-r_DufWRa6J-UzQ8_76-OHdgdwVVFlYTy4xmYbQq1CnPre1CCzFQDsyzdnIKIbXS5vPUvPTmcGIAYb6c',
        },
        {
            name: 'products.sand.dakar_name'|trans,
            slug: null,
            alt: 'products.sand.dakar_alt'|trans,
            description: 'products.sand.dakar_desc'|trans,
            image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCLhVLFe0itU6I94NVVor6LoOmvm_eIq0fyYIvnJVY8JpTOe0Az-SjWjPWK0WxrQ9QmkGbm6ek25sEH3rS5Uvj7RGU9_QBRomDdN6_vU9fmkzlb-aOESeO_S-NBOVXw3rPtuAmfT-tZQ6J1LTb25WCIR8-ntdTlNUH1R6R0gg1Nr_5WcGKx7CG2tKUaoxXdT2aF7N6ZZcCjOQU7XHD3_m6OoSPaPWwuTwyrevTYBIFv48n09pv0yLU16MU682u__E7tdNbL-bXhxdQ',
        },
    ] %}

    <div class="grid md:grid-cols-2 gap-8">
        {% for product in sand_products %}
            <article class="bg-white flex flex-col md:flex-row shadow-sm border border-gray-100 overflow-hidden opacity-0"
                     data-scroll-reveal-target="item">
                <img alt="{{ product.alt }}"
                     class="w-full md:w-1/2 h-64 object-cover"
                     loading="lazy"
                     width="400"
                     height="256"
                     src="{{ product.image }}">
                <div class="p-8 flex flex-col justify-center">
                    <h3 class="text-2xl font-bold text-primary mb-2">{{ product.name }}</h3>
                    <p class="text-gray-600 mb-6">{{ product.description }}</p>
                    <a href="{{ product.slug ? path('app_products_show', {slug: product.slug}) : path('app_quote') }}" class="inline-block bg-primary text-white px-8 py-3 font-bold uppercase text-xs tracking-widest hover:bg-primary/90 transition-colors self-start text-center">
                        {{ product.slug ? ('products.sand.order_now'|trans) : ('products.sand.request_quote'|trans) }}
                    </a>
                </div>
            </article>
        {% endfor %}
    </div>
</section>
