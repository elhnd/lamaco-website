{# Product detail — Info panel (title, description, status, CTAs, project context) #}
<div class="space-y-8">
    {# Badge + Title + Description #}
    <div>
        <span class="inline-block bg-accent text-white px-3 py-1 text-[10px] font-bold uppercase rounded-sm mb-4 tracking-[0.2em]">
            {{ product.badge }}
        </span>
        <h2 class="text-4xl md:text-5xl font-extrabold text-primary mb-6 tracking-tight">{{ product.name }}</h2>
        <p class="text-lg text-gray-600 leading-relaxed font-light">
            {{ product.description }}
        </p>
    </div>

    {# Stock status + pricing #}
    <div class="flex items-center gap-6 py-6 border-y border-gray-100">
        <div class="flex items-center gap-2">
            <span class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
            <span class="font-bold text-sm text-gray-800 uppercase tracking-widest">{{ product.status }}</span>
        </div>
        <div class="h-4 w-px bg-gray-200"></div>
        <p class="text-sm font-medium text-primary italic">Inquire for Bulk Pricing</p>
    </div>

    {# CTA Buttons #}
    <div class="flex flex-col sm:flex-row gap-4">
        <a href="{{ path('app_quote') }}"
           class="flex-1 bg-primary text-white py-5 px-8 rounded font-bold uppercase text-xs tracking-[0.15em] hover:bg-opacity-95 transition-all shadow-lg text-center">
            Request Quote for this Product
        </a>
        <a href="https://wa.me/221770000000?text={{ ('Hello, I would like to order ' ~ product.name)|url_encode }}"
           target="_blank"
           rel="noopener noreferrer"
           class="flex-none bg-accent text-white py-5 px-10 rounded font-bold uppercase text-xs tracking-[0.15em] hover:brightness-105 transition-all flex items-center justify-center gap-2 shadow-lg">
            <span class="material-symbols-outlined text-sm">chat</span>
            Order via WhatsApp
        </a>
    </div>

    {# Project Context #}
    {% if product.projectContext %}
        <div class="bg-slate-50 p-6 rounded border border-slate-200 flex items-center gap-6">
            <img alt="{{ product.projectContext.name }}"
                 class="w-20 h-20 object-cover rounded shadow-sm flex-shrink-0"
                 loading="lazy"
                 src="{{ product.projectContext.image }}">
            <div>
                <h4 class="text-xs font-bold uppercase text-gray-400 tracking-widest mb-1">Project Context</h4>
                <p class="text-sm font-bold text-primary">
                    Recently used in:
                    <span class="underline underline-offset-4 decoration-accent">{{ product.projectContext.name }}</span>
                </p>
            </div>
        </div>
    {% endif %}
</div>
