{# Product detail — Technical Specifications grid #}
<section class="mb-24" data-controller="scroll-reveal">
    <div class="flex items-center gap-4 mb-10 opacity-0" data-scroll-reveal-target="item">
        <h2 class="text-2xl font-bold text-primary uppercase tracking-wider">{{ 'products.detail.tech_specs'|trans }}</h2>
        <div class="h-[1px] flex-grow bg-gray-200"></div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200 border border-gray-200 opacity-0"
         data-scroll-reveal-target="item">
        {% for spec in product.specs %}
            <div class="bg-white p-8">
                <span class="block text-xs font-bold text-gray-400 uppercase mb-2 tracking-widest">{{ spec.label }}</span>
                <p class="{{ spec.small|default(false) ? 'text-sm' : 'text-xl' }} font-bold text-primary">{{ spec.value }}</p>
            </div>
        {% endfor %}
    </div>
</section>
