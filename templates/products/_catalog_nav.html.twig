            <a class="text-xs font-bold text-primary uppercase tracking-widest hover:text-accent transition-colors" href="#basalt">{{ 'products.catalog_nav.basalt'|trans }}</a>
            <a class="text-xs font-bold text-primary uppercase tracking-widest hover:text-accent transition-colors" href="#equipment">{{ 'products.catalog_nav.equipment'|trans }}</a>
        </div>
    </div>
