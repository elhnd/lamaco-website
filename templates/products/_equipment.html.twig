{# Heavy Equipment Rental Section — Feature card with image #}
<section id="equipment" aria-labelledby="equipment-heading" data-controller="scroll-reveal">
    <div class="flex items-center gap-4 mb-10 opacity-0" data-scroll-reveal-target="item">
        <h2 id="equipment-heading" class="text-3xl font-bold text-primary font-display">{{ 'products.equipment.title'|trans }}</h2>
        <div class="h-1 flex-grow bg-gray-200" aria-hidden="true"></div>
    </div>

    <div class="bg-white shadow-2xl rounded-xl overflow-hidden flex flex-col lg:flex-row opacity-0"
         data-scroll-reveal-target="item">
        <div class="lg:w-1/2 relative">
            <img alt="{{ 'products.equipment.alt_image'|trans }}"
                 class="w-full h-full object-cover min-h-[400px]"
                 loading="lazy"
                 width="640"
                 height="400"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuAHMU3No4Lxtodiak16PwpIiSkxfd-ZhYAyZ6MzHqcqkztOUFSk3PE83yRUqarerBJscRYEovVXJp5LKQbgsFN7MkN-53pfi6K3ca6O_J8WrDkm0_ABfjuHOLIzo7XG7wvIOsy68ln_6kv4Kb1Y3nH9VLA_La7wEmC_kITjIv-IeOLKSX2bVj8MQAItSWBURlXGeHI5Kduh8R9-KhVmIgDJOEJTExFI-o1OEmb8_mlj9YbRlf9CMFD129syZXJtqWe6axYLPQJD8ag">
            <div class="absolute top-6 left-6 bg-accent text-white px-4 py-2 font-bold text-xs uppercase tracking-widest rounded shadow-lg">
                {{ 'products.equipment.badge'|trans }}
            </div>
        </div>
        <div class="lg:w-1/2 p-12 flex flex-col justify-center">
            <h3 class="text-3xl font-bold text-primary mb-4">{{ 'products.equipment.rental_title'|trans }}</h3>
            <p class="text-gray-600 text-lg mb-8 leading-relaxed">
                {{ 'products.equipment.rental_desc'|trans }}
            </p>
            <ul class="space-y-4 mb-10 text-gray-700">
                <li class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent" aria-hidden="true">check_circle</span>
                    {{ 'products.equipment.feature_support'|trans }}
                </li>
                <li class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent" aria-hidden="true">check_circle</span>
                    {{ 'products.equipment.feature_terms'|trans }}
                </li>
                <li class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent" aria-hidden="true">check_circle</span>
                    {{ 'products.equipment.feature_delivery'|trans }}
                </li>
            </ul>
            <a class="bg-primary text-white text-center py-4 rounded font-bold uppercase tracking-widest hover:bg-primary/90 transition-all"
               href="{{ path('app_quote') }}">
                {{ 'products.equipment.check_availability'|trans }}
            </a>
        </div>
    </div>
</section>
