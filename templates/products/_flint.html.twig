{# Flint / Mapaté Concrete Section — Product cards with images #}
<section id="flint" aria-labelledby="flint-heading" data-controller="scroll-reveal">
    <div class="flex items-center gap-4 mb-10 opacity-0" data-scroll-reveal-target="item">
        <h2 id="flint-heading" class="text-3xl font-bold text-primary font-display">{{ 'products.flint.title'|trans }}</h2>
        <div class="h-1 flex-grow bg-gray-200" aria-hidden="true"></div>
        <span class="bg-accent/10 text-accent px-3 py-1 text-xs font-bold uppercase rounded">{{ 'products.flint.badge'|trans }}</span>
    </div>

    {% set flint_products = [
        {
            name: 'products.flint.product_8_16'|trans,
            slug: 'basalt-8-16',
            alt: 'products.flint.alt_8_16'|trans,
            description: 'products.flint.desc_8_16'|trans,
            image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuC3McL5hTcXxQ1tpTx9uCMtlkk4gywNbEEW7JPgwtej9PDS7fmRR5drT-9tgs5w4lZvcnKRRezuUXSeOz5Wy41Jle3jBT87LrSDyr4HN3LzgVa37RuRNf-I50RZArrgpfOeLfyyR17sk9Z6J1Lkzi86IoJ844NIsyB2kzH5EAzr2AGiYpotMMzx6jKgrMuzTwnHWq7S70aI72K4DX90G5b-VeI1eV4ygA3I-a9KapwbiuMJc6I_FU-91UVVPfT6o5FFioU2NWNDBRg',
            status: 'products.flint.stocked'|trans,
        },
        {
            name: 'products.flint.product_3_8'|trans,
            slug: 'basalt-3-8',
            alt: 'products.flint.alt_3_8'|trans,
            description: 'products.flint.desc_3_8'|trans,
            image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuDupnOz2zNNc-WoUcyetHBXj2peqRqUtOsc9OfqvHqxUPHgfWKmvB0xXnLKC2c2GBt1XTEqHLlt--8Tm7Ikr-81XWme3y6HkVk90cuiPLjbkIr-_NXa8ljgvXsJdzPSERB0ouS0vHgV9bNlnYQb5ox3j_FzYLcapk8Lx2VQaTo0PDHwN-n7QtiEptnpplvAGF0YXHDW2CF16Rrpv9fEMKIKV3NxAm9KB8lPFCTbXO2_iDyNuQsLT0UUuMQyEt90k5lcqduhyt715_Y',
            status: 'products.flint.stocked'|trans,
        },
        {
            name: 'products.flint.product_0_3'|trans,
            slug: 'basalt-0-3',
            alt: 'products.flint.alt_0_3'|trans,
            description: 'products.flint.desc_0_3'|trans,
            image: 'https://lh3.googleusercontent.com/aida-public/AB6AXuD9tIQ7yLg5dZ6hG2UUjGRZhscYp621ecQGMXzkwwrrvQNjQdpnLuVNZmToSloj2uDHZbMsDV1WqGEcU_neJHwhqSKYTpkOoHVaHqDDum1Re13T4quj341MszeSM6mYeph-G_GBYWPdCeGo7Df2NhH9rdIbYEndwkY_q1QWguEliDBxVy7dsPn9ZFdweTP1T1QRJDkv4bWHfwfuiX2YjjmWSWRj8cxxpjNYTLg-csEdx7HcMW2vaRXavjzj1eNFGgQD3LCH29ySBb0',
            status: 'products.flint.stocked'|trans,
        },
    ] %}

    <div class="grid md:grid-cols-3 gap-8">
        {% for product in flint_products %}
            <article class="bg-white group overflow-hidden shadow-sm hover:shadow-xl transition-all border border-gray-100 opacity-0"
                     data-scroll-reveal-target="item">
                <div class="overflow-hidden">
                    <img alt="{{ product.alt }}"
                         class="product-card-img"
                         loading="lazy"
                         width="400"
                         height="192"
                         src="{{ product.image }}">
                </div>
                <div class="p-6">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-xl font-bold text-primary">{{ product.name }}</h3>
                        <span class="text-xs font-bold text-accent">{{ product.status }}</span>
                    </div>
                    <p class="text-gray-600 text-sm mb-6">{{ product.description }}</p>
                    <a href="{{ path('app_products_show', {slug: product.slug}) }}" class="block w-full bg-primary text-white py-3 font-bold uppercase text-xs tracking-widest hover:bg-primary/90 transition-colors text-center">
                        {{ 'products.flint.order_now'|trans }}
                    </a>
                </div>
            </article>
        {% endfor %}
    </div>
</section>
