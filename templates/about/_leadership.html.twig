<section class="py-24 bg-background-light" id="leadership" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 opacity-0" data-scroll-reveal-target="item">
            <span class="text-accent font-bold uppercase tracking-widest text-sm mb-4 block">{{ 'about.leadership.subtitle'|trans }}</span>
            <h2 class="text-4xl font-bold text-primary font-display">{{ 'about.leadership.title'|trans }}</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-12">
            {% for leader in leaders %}
                <article class="group opacity-0" data-scroll-reveal-target="item">
                    <div class="aspect-[4/5] bg-gray-200 rounded overflow-hidden mb-6 grayscale hover:grayscale-0 transition-all duration-500">
                        <img alt="{{ leader.name }} — {{ leader.role }}"
                             class="w-full h-full object-cover"
                             loading="lazy"
                             src="{{ leader.image }}">
                    </div>
                    <h4 class="text-xl font-bold text-primary font-display">{{ leader.name }}</h4>
                    <p class="text-accent font-bold text-xs uppercase tracking-widest">{{ leader.role }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
