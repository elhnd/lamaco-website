{# About — Core Values Section #}
{% set values = [
    { icon: 'verified', title: 'Reliability', description: 'We deliver what we promise, when we promise it. Consistency is the hallmark of our service.' },
    { icon: 'lightbulb', title: 'Innovation', description: 'We optimize logistics through technology and modern fleet management for maximum efficiency.' },
    { icon: 'workspace_premium', title: 'Professionalism', description: 'Our team embodies the highest standards of integrity and expertise in every interaction.' },
    { icon: 'health_and_safety', title: 'Safety', description: 'Zero-compromise approach to site safety and the well-being of our operators and partners.' },
] %}

<section class="py-24 bg-white" id="values" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 opacity-0" data-scroll-reveal-target="item">
            <span class="text-accent font-bold uppercase tracking-widest text-sm mb-4 block">Core Principles</span>
            <h2 class="text-4xl font-bold text-primary font-display">The Values that Drive Us</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for value in values %}
                <div class="text-center p-8 border border-gray-100 rounded hover:shadow-md transition-shadow opacity-0"
                     data-scroll-reveal-target="item">
                    <div class="inline-flex w-16 h-16 bg-primary/5 rounded-full items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-accent text-3xl">{{ value.icon }}</span>
                    </div>
                    <h4 class="text-xl font-bold text-primary mb-3">{{ value.title }}</h4>
                    <p class="text-gray-600 text-sm leading-relaxed">{{ value.description }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
