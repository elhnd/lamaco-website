{# About — Core Values Section #}
{% set values = [
    { icon: 'verified', title: 'about.values.reliability'|trans, description: 'about.values.reliability_desc'|trans },
    { icon: 'lightbulb', title: 'about.values.innovation'|trans, description: 'about.values.innovation_desc'|trans },
    { icon: 'workspace_premium', title: 'about.values.professionalism'|trans, description: 'about.values.professionalism_desc'|trans },
    { icon: 'health_and_safety', title: 'about.values.safety'|trans, description: 'about.values.safety_desc'|trans },
] %}

<section class="py-24 bg-white" id="values" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 opacity-0" data-scroll-reveal-target="item">
            <span class="text-accent font-bold uppercase tracking-widest text-sm mb-4 block">{{ 'about.values.subtitle'|trans }}</span>
            <h2 class="text-4xl font-bold text-primary font-display">{{ 'about.values.title'|trans }}</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for value in values %}
                <div class="text-center p-8 border border-gray-100 rounded hover:shadow-md transition-shadow opacity-0"
                     data-scroll-reveal-target="item">
                    <div class="inline-flex w-16 h-16 bg-primary/5 rounded-full items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-accent text-3xl">{{ value.icon }}</span>
                    </div>
                    <h4 class="text-xl font-bold text-primary mb-3">{{ value.title }}</h4>
                    <p class="text-gray-600 text-sm leading-relaxed">{{ value.description }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
