{% extends 'base.html.twig' %}

{% block title %}{{ 'about.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'about.meta.description'|trans }}{% endblock %}
{% block og_title %}{{ 'about.meta.og_title'|trans }}{% endblock %}
{% block og_description %}{{ 'about.meta.og_description'|trans }}{% endblock %}

{% block header %}
    {% include 'partials/_navbar.html.twig' %}
    {% include 'partials/_hero.html.twig' with {
        hero_overlay: 'hero-about-overlay',
        hero_subtitle: 'about.hero.subtitle'|trans,
        hero_title: 'about.hero.title'|trans,
        hero_description: 'about.hero.description'|trans,
        hero_accent_line: true,
    } %}
{% endblock %}

{% block body %}
    {% include 'about/_story.html.twig' %}
    {% include 'about/_mission_vision.html.twig' %}
    {% include 'about/_values.html.twig' %}
    {% include 'about/_leadership.html.twig' %}
    {% include 'about/_partners.html.twig' %}
{% endblock %}
