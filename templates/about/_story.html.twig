{# About — Our Story Section #}
<section class="py-24 bg-white" id="story" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            {# Image with established badge #}
            <div class="relative opacity-0" data-scroll-reveal-target="item">
                <img alt="{{ 'about.story.alt_image'|trans }}"
                     class="rounded shadow-2xl w-full object-cover h-[500px]"
                     loading="lazy"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuATZw85lA-bBx_tJ5sJJuGf1FXuL-wtGpqZj90ZgsWRNuL2TS_q5jzcqOZh6GcFDbTwXt89n8-jRydjxxrKg9dDzbkXeaBYny6VtPU3tDrz-syfUDgJY64peD2CFBlgMmBDIx8UIKXQUkkGvyd2MVnv0GyPdif2SU7irDy_lSbe3AmrQcHBB1v9x2-bAsNgLP5fKE5-w65JbNl2qmT2AZ0EN8qXUoCJMChQ3AN-VqJ4f3aQmJxr6gMF5qSCCKSmKePSDYw3XEDWMKc">
                <div class="absolute -bottom-6 -right-6 bg-accent p-8 rounded shadow-xl hidden md:block">
                    <p class="text-primary text-sm uppercase tracking-widest font-bold">{{ 'about.story.badge'|trans }}</p>
                    <span class="text-white text-4xl font-bold font-display">{{ 'about.story.badge_year'|trans }}</span>
                </div>
            </div>

            {# Story text #}
            <div class="space-y-6 opacity-0" data-scroll-reveal-target="item">
                <h2 class="text-4xl font-bold text-primary leading-tight">{{ 'about.story.title'|trans }}</h2>
                <p class="text-gray-600 text-lg leading-relaxed">
                    {{ 'about.story.paragraph1'|trans }}
                </p>
                <p class="text-gray-600 text-lg leading-relaxed">
                    {{ 'about.story.paragraph2'|trans }}
                </p>
                <div class="pt-4">
                    <blockquote class="flex items-center gap-4 border-l-4 border-accent pl-6 py-2">
                        <p class="italic text-primary font-medium text-xl">
                            {{ 'about.story.quote'|trans }}
                        </p>
                    </blockquote>
                </div>
            </div>
        </div>
    </div>
</section>
