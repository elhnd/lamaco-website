{# About — Mission & Vision Section #}
<section class="py-24 bg-background-light" id="mission" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">
            {# Mission card #}
            <div class="bg-primary p-12 rounded shadow-lg text-white opacity-0" data-scroll-reveal-target="item">
                <div class="w-16 h-16 bg-accent/20 rounded flex items-center justify-center mb-8">
                    <span class="material-symbols-outlined text-accent text-4xl">track_changes</span>
                </div>
                <h3 class="text-3xl font-bold mb-6 font-display">{{ 'about.mission.title'|trans }}</h3>
                <p class="text-gray-200 text-lg leading-relaxed">
                    {{ 'about.mission.description'|trans }}
                </p>
            </div>

            {# Vision card #}
            <div class="bg-white p-12 rounded shadow-lg border-2 border-primary text-primary opacity-0" data-scroll-reveal-target="item">
                <div class="w-16 h-16 bg-primary/5 rounded flex items-center justify-center mb-8">
                    <span class="material-symbols-outlined text-accent text-4xl">visibility</span>
                </div>
                <h3 class="text-3xl font-bold mb-6 font-display">{{ 'about.vision.title'|trans }}</h3>
                <p class="text-gray-600 text-lg leading-relaxed">
                    {{ 'about.vision.description'|trans }}
                </p>
            </div>
        </div>
    </div>
</section>
