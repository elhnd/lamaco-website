{# Quote — Multi-step form with service selection, project details, contact info #}
{% set services = [
    { icon: 'conveyor_belt', title: 'quote.form.materials_supply'|trans, description: 'quote.form.materials_supply_desc'|trans },
    { icon: 'precision_manufacturing', title: 'quote.form.equipment_rental'|trans, description: 'quote.form.equipment_rental_desc'|trans },
    { icon: 'home_repair_service', title: 'quote.form.both_services'|trans, description: 'quote.form.both_services_desc'|trans },
] %}

{% set regions = [
    'Dakar', 'Thiès', 'Saint-Louis', 'Diourbel', 'Kaolack',
    'Ziguinchor', 'Kolda', 'Fatick', 'Matam', 'Kaffrine',
    'Kédougou', 'Sédhiou', 'Tambacounda', 'Louga',
] %}

<section class="py-16" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-3 gap-12">
            {# ── Left column: Form ── #}
            <div class="lg:col-span-2 opacity-0" data-scroll-reveal-target="item">
                <div class="bg-white p-8 md:p-12 rounded shadow-sm border border-gray-100">
                    <form action="#" method="post" class="space-y-8">
                        {# Step 1 — Service Category #}
                        <div>
                            <h3 class="text-2xl font-bold text-primary mb-8">{{ 'quote.form.select_service'|trans }}</h3>
                            <div class="grid md:grid-cols-3 gap-6">
                                {% for service in services %}
                                    <label class="card-selection border-2 border-gray-100 p-6 rounded text-left transition-all cursor-pointer block">
                                        <input type="radio"
                                               name="service_category"
                                               value="{{ service.title }}"
                                               class="sr-only peer">
                                        <span class="material-symbols-outlined text-accent text-3xl mb-4 block">{{ service.icon }}</span>
                                        <h4 class="font-bold text-primary mb-2">{{ service.title }}</h4>
                                        <p class="text-xs text-gray-500">{{ service.description }}</p>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>

                        {# Step 2 — Project Details #}
                        <div class="grid md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label for="quote_region" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.project_location'|trans }}</label>
                                <select id="quote_region"
                                        name="region"
                                        required
                                        class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent text-gray-600">
                                    <option value="">{{ 'quote.form.select_region'|trans }}</option>
                                    {% for region in regions %}
                                        <option value="{{ region }}">{{ region }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label for="quote_date" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.start_date'|trans }}</label>
                                <input id="quote_date"
                                       name="start_date"
                                       type="date"
                                       class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="quote_requirements" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.requirements'|trans }}</label>
                            <textarea id="quote_requirements"
                                      name="requirements"
                                      rows="4"
                                      required
                                      class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent"
                                      placeholder="{{ 'quote.form.requirements_placeholder'|trans }}"></textarea>
                        </div>

                        {# Step 3 — Contact Information #}
                        <div class="pt-8 border-t border-gray-100">
                            <h3 class="text-xl font-bold text-primary mb-6">{{ 'quote.form.contact_info'|trans }}</h3>
                            <div class="grid md:grid-cols-2 gap-6">
                                <div class="space-y-2">
                                    <label for="quote_company" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.company_name'|trans }}</label>
                                    <input id="quote_company"
                                           name="company"
                                           type="text"
                                           autocomplete="organization"
                                           class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent"
                                           placeholder="{{ 'quote.form.company_placeholder'|trans }}">
                                </div>
                                <div class="space-y-2">
                                    <label for="quote_name" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.contact_person'|trans }}</label>
                                    <input id="quote_name"
                                           name="contact_person"
                                           type="text"
                                           autocomplete="name"
                                           required
                                           class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent"
                                           placeholder="{{ 'quote.form.contact_placeholder'|trans }}">
                                </div>
                                <div class="space-y-2">
                                    <label for="quote_phone" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.phone_number'|trans }}</label>
                                    <input id="quote_phone"
                                           name="phone"
                                           type="tel"
                                           autocomplete="tel"
                                           required
                                           class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent"
                                           placeholder="+221 ...">
                                </div>
                                <div class="space-y-2">
                                    <label for="quote_email" class="block text-sm font-bold text-primary uppercase tracking-wide">{{ 'quote.form.email_address'|trans }}</label>
                                    <input id="quote_email"
                                           name="email"
                                           type="email"
                                           autocomplete="email"
                                           required
                                           class="w-full border-gray-200 rounded p-3 focus:ring-accent focus:border-accent"
                                           placeholder="email@company.com">
                                </div>
                            </div>
                        </div>

                        {# Submit #}
                        <div class="pt-6">
                            <button type="submit"
                                    class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-5 rounded transition-all uppercase tracking-widest text-lg shadow-lg">
                                {{ 'quote.form.submit'|trans }}
                            </button>
                            <p class="text-center text-gray-400 text-xs mt-4 italic">
                                {{ 'quote.form.legal'|trans }}
                            </p>
                        </div>
                    </form>
                </div>
            </div>

            {# ── Right column: Sidebar ── #}
            <div class="lg:col-span-1 space-y-8 opacity-0" data-scroll-reveal-target="item">
                {% include 'quote/_sidebar.html.twig' %}
            </div>
        </div>
    </div>
</section>
