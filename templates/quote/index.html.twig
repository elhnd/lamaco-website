{% extends 'base.html.twig' %}

{% block title %}{{ 'quote.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'quote.meta.description'|trans }}{% endblock %}
{% block og_title %}{{ 'quote.meta.og_title'|trans }}{% endblock %}
{% block og_description %}{{ 'quote.meta.og_description'|trans }}{% endblock %}

{% block header %}
    {% include 'partials/_navbar.html.twig' %}
    {% include 'partials/_hero.html.twig' with {
        hero_overlay: 'hero-quote-overlay',
        hero_title: 'quote.hero.title'|trans,
        hero_description: 'quote.hero.description'|trans,
        hero_accent_line: true,
    } %}
{% endblock %}

{% block body %}
    {% include 'quote/_form.html.twig' %}
{% endblock %}
