{% extends 'base.html.twig' %}

{% block title %}{{ 'contact.meta.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'contact.meta.description'|trans }}{% endblock %}
{% block og_title %}{{ 'contact.meta.og_title'|trans }}{% endblock %}
{% block og_description %}{{ 'contact.meta.og_description'|trans }}{% endblock %}

{% block header %}
    {% include 'partials/_navbar.html.twig' %}
    {% include 'partials/_hero.html.twig' with {
        hero_overlay: 'hero-contact-overlay',
        hero_title: 'contact.hero.title'|trans,
        hero_description: 'contact.hero.description'|trans,
        hero_accent_line: true,
    } %}
{% endblock %}

{% block body %}
    {% include 'contact/_info_cards.html.twig' %}
    {% include 'partials/_contact_form.html.twig' %}
    {% include 'contact/_map.html.twig' %}
{% endblock %}
