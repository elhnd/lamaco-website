{# Contact — Info Cards (Headquarters with map, Phone, Email) #}
<section class="py-16 -mt-12 relative z-20" data-controller="scroll-reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8">
            {# Headquarters card with Google Maps #}
            <div class="bg-white shadow-xl rounded-lg border-t-4 border-accent overflow-hidden opacity-0"
                 data-scroll-reveal-target="item">
                <div class="p-8">
                    <div class="w-12 h-12 bg-primary/10 rounded flex items-center justify-center mb-6">
                        <span class="material-symbols-outlined text-primary text-3xl">location_on</span>
                    </div>
                    <h3 class="text-xl font-bold text-primary mb-4 font-display">{{ 'contact.info.headquarters'|trans }}</h3>
                    <p class="text-gray-600 mb-4 leading-relaxed">
                        {{ 'contact.info.address'|trans }}<br>{{ 'contact.info.address2'|trans }}
                    </p>
                    <a class="text-accent font-bold text-sm uppercase tracking-wider flex items-center gap-2 hover:gap-3 transition-all"
                       href="https://www.google.com/maps/place/Dakar,+Senegal/@14.6928,-17.4677,15z"
                       target="_blank"
                       rel="noopener noreferrer">
                        {{ 'contact.info.view_map'|trans }}
                        <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
            </div>

            {# Phone & WhatsApp card #}
            <div class="bg-white p-8 shadow-xl rounded-lg border-t-4 border-accent opacity-0"
                 data-scroll-reveal-target="item">
                <div class="w-12 h-12 bg-primary/10 rounded flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-primary text-3xl">call</span>
                </div>
                <h3 class="text-xl font-bold text-primary mb-4 font-display">{{ 'contact.info.phone_whatsapp'|trans }}</h3>
                <div class="space-y-3">
                    <a href="tel:+221338000000" class="text-primary font-bold text-lg block hover:text-accent transition-colors">
                        +221 33 800 00 00
                    </a>
                    <a href="https://wa.me/221770000000"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="flex items-center gap-3 text-green-600 font-bold hover:text-green-700 transition-colors">
                        <img alt="WhatsApp" class="w-5 h-5" src="{{ asset('images/icon/whatsapp.svg') }}">
                        <span>+221 77 000 00 00</span>
                    </a>
                </div>
            </div>

            {# Email & Hours card #}
            <div class="bg-white p-8 shadow-xl rounded-lg border-t-4 border-accent opacity-0"
                 data-scroll-reveal-target="item">
                <div class="w-12 h-12 bg-primary/10 rounded flex items-center justify-center mb-6">
                    <span class="material-symbols-outlined text-primary text-3xl">mail</span>
                </div>
                <h3 class="text-xl font-bold text-primary mb-4 font-display">{{ 'contact.info.email_hours'|trans }}</h3>
                <a href="mailto:contact@lamaco-sn.com" class="text-gray-600 mb-2 font-medium block hover:text-accent transition-colors">
                    contact@lamaco-sn.com
                </a>
                <div class="mt-4 pt-4 border-t border-gray-100">
                    <p class="text-xs text-gray-400 uppercase tracking-widest mb-1 font-bold">{{ 'contact.info.business_hours'|trans }}</p>
                    <p class="text-sm text-gray-600">{{ 'contact.info.hours_weekday'|trans }}</p>
                    <p class="text-sm text-gray-600">{{ 'contact.info.hours_saturday'|trans }}</p>
                </div>
            </div>
        </div>
    </div>
</section>
